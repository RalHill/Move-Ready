# =============================================================
# MOVE READY PLUS - Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase (REQUIRED - used by both client and server)
# These MUST have the NEXT_PUBLIC_ prefix to be available in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Geoapify Maps API Key (REQUIRED for live tracking map)
NEXT_PUBLIC_GEOAPIFY_KEY=your_geoapify_key_here

# =============================================================
# VERCEL DEPLOYMENT - Add these exact variable names in Vercel:
# Settings → Environment Variables → Add New
#
# NEXT_PUBLIC_SUPABASE_URL  = https://zbiulljwpiwkljhtrulc.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY = eyJhbGci... (your anon key)
# NEXT_PUBLIC_GEOAPIFY_KEY  = your_geoapify_key
#
# IMPORTANT: Enter the actual values directly.
# Do NOT use Vercel Secrets syntax ($secret_name or @secret_name).
# Set environment scope to: Production + Preview + Development
# =============================================================
